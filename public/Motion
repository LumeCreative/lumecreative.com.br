    }, { threshold: [0, 0.45, 0.9] });
    this.stageRefs.forEach(r => { if (r.current) this._io.observe(r.current); });
  }

  componentWillUnmount() {
    (this._blobUrls || []).forEach(u => URL.revokeObjectURL(u));
    if (this._io) this._io.disconnect();
  }

  _goTo(i) {
    const el = this.stageRefs[i] && this.stageRefs[i].current;
    if (!el) return;
    const top = el.getBoundingClientRect().top + window.scrollY - 80;
    window.scrollTo({ top, behavior: 'smooth' });
  }

  renderVals() {
    const nums = Array.from({ length: 8 }, (_, i) => String(i + 1).padStart(2, '0'));
    const works = nums.map((n, i) => ({
      n,
      title: 'Project ' + (i + 1),
      ref: this.workRefs[i],
      stageRef: this.stageRefs[i],
      frameRef: this.frameRefs[i],
    }));

    const navItems = nums.map((n, i) => ({
      label: n,
      go: () => this._goTo(i),
      style: {
        fontFamily: "'IBM Plex Mono',monospace",
        fontSize: '11px',
        letterSpacing: '.08em',
        cursor: 'pointer',
        userSelect: 'none',
        transition: 'color .4s, opacity .4s',
        color: this.state.active === i ? '#C8A87C' : '#F4F1EC',
        opacity: this.state.active === i ? 1 : 0.32,
      },
    }));

    const services = [
      { name: 'Brand Motion', desc: 'Animated identity systems and logo reveals that make a brand unmistakable in any feed.' },
      { name: 'Motion Graphics', desc: 'Explainers, kinetic typography and data brought to life with rhythm and intent.' },
      { name: 'Social & Performance', desc: 'Scroll-stopping vertical and square creative engineered for paid social and launches.' },
      { name: '3D & Compositing', desc: 'Photoreal 3D, product animation and compositing for premium, cinematic films.' },
    ];

    const email = 'lucas' + '@' + 'growthbylume' + '.com.br';
    return { works, navItems, services, email, mailto: 'mailto:' + email };
  }
}
</script>
</body>
</html>

