    files.forEach((f, i) => {
      const v = this.workRefs[i] && this.workRefs[i].current;
      if (!v) return;
      v.addEventListener('loadedmetadata', () => {
        const frame = this.frameRefs[i] && this.frameRefs[i].current;
        if (!frame || !v.videoWidth) return;
        frame.style.aspectRatio = v.videoWidth + '/' + v.videoHeight;
        if (v.videoHeight > v.videoWidth) { frame.style.maxWidth = '400px'; }
      });
      fetch('videos/' + f + '.mp4').then(r => r.blob()).then(b => {
        const url = URL.createObjectURL(b);
        this._blobUrls.push(url);
        v.src = url;
        v.load();
        if (this._visible[i]) { const p = v.play(); if (p && p.catch) p.catch(() => {}); }
      }).catch(() => {});
    });

    this._io = new IntersectionObserver((entries) => {
      entries.forEach((e) => {
        const idx = this.stageRefs.findIndex(r => r.current === e.target);
        if (idx < 0) return;
        const v = this.workRefs[idx].current;
        const on = e.isIntersecting && e.intersectionRatio >= 0.45;
        this._visible[idx] = on;
        if (on) {
          e.target.style.opacity = '1';
          e.target.style.transform = 'translateY(0)';
          if (v) { const p = v.play(); if (p && p.catch) p.catch(() => {}); }
          this.setState({ active: idx });
        } else {
          if (v) v.pause();
          if (this.state.active === idx) this.setState({ active: -1 });
        }
